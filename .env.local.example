# Local development: libSQL with a local file (no auth token needed)
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# Production (set these in Vercel project settings, do NOT commit):
# TURSO_DATABASE_URL=libsql://<your-db>-<org>.turso.io
# TURSO_AUTH_TOKEN=<token from `turso db tokens create <db>`>
