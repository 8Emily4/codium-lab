# 이 파일을 `.env`로 복사한 뒤 값을 채우세요: `cp .env.example .env`
# Next.js는 `.env`를 자동으로 읽습니다. (.env 는 git에 커밋되지 않습니다)

# ── Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Database — Turso (libSQL)
# 로컬: 파일 DB (auth token 불필요)
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=
# 운영(Vercel 등 환경변수로 설정):
#   TURSO_DATABASE_URL=libsql://<your-db>-<org>.turso.io
#   TURSO_AUTH_TOKEN=<turso db tokens create 로 발급>

# ── Auth — Kakao OAuth
# https://developers.kakao.com/console/app → 내 애플리케이션 → 앱 키 / 카카오 로그인
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=optional-client-secret-if-enabled
KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/kakao/callback
# Optional. Comma-separated scopes that are REGISTERED in Kakao Developers.
# Examples:
#   KAKAO_SCOPES=profile_nickname
#   KAKAO_SCOPES=profile_nickname,profile_image
#   KAKAO_SCOPES=profile_nickname,profile_image,account_email  # email needs biz-app review
# If left blank, Kakao uses the required-consent items configured in the console.
KAKAO_SCOPES=

# Cookie signing — `openssl rand -hex 32`
AUTH_SECRET=replace-with-32-byte-hex

# ── Super admins (워크스페이스 최상위 권한)
# 쉼표로 구분된 "세션 ID" 목록. 카카오 사용자는 "kakao:<숫자ID>" 형태입니다.
# 여기 등록된 사용자만 슈퍼관리자가 되고, DB로는 절대 변경할 수 없습니다.
# 본인 ID 확인: 한 번 로그인한 뒤 `npm run whoami` 실행.
# 예) 한 명:    SUPER_ADMIN_IDS=kakao:1234567890
# 예) 여러 명:  SUPER_ADMIN_IDS=kakao:1234567890,kakao:9876543210
SUPER_ADMIN_IDS=

# ── Future providers (placeholder)
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# META_CLIENT_ID=
# META_CLIENT_SECRET=
