# 이 파일을 `.env`로 복사한 뒤 값을 채우세요: `cp .env.example .env`
# Next.js는 `.env`를 자동으로 읽습니다. (.env 는 git에 커밋되지 않습니다)

# ── 포트 (개발 서버 / next dev·start) ───────────────────────────────────────
# 3000·8080 등은 다른 프로젝트와 자주 충돌 → 전용 포트 사용.
# 같은 머신의 다른 프로젝트와 겹치지 않게 103xx 대역 할당:
#   code-pulse 100xx/101xx · codium-lab-chat 102xx · codium-lab(여기) 103xx
# package.json 의 dev/start 스크립트가 이 PORT 값을 읽어 바인딩합니다.
PORT=10380

# ── Site
# 포트를 바꾸면 아래 두 URL(SITE_URL·KAKAO_REDIRECT_URI)의 포트도 함께 맞추세요.
NEXT_PUBLIC_SITE_URL=http://localhost:10380

# ── Database — Turso (libSQL)
# 로컬: 파일 DB (auth token 불필요)
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=
# 운영(Vercel 등 환경변수로 설정):
#   TURSO_DATABASE_URL=libsql://<your-db>-<org>.turso.io
#   TURSO_AUTH_TOKEN=<turso db tokens create 로 발급>

# ── Auth — Kakao OAuth
# https://developers.kakao.com/console/app → 내 애플리케이션 → 앱 키 / 카카오 로그인
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=optional-client-secret-if-enabled
KAKAO_REDIRECT_URI=http://localhost:10380/api/auth/kakao/callback
# Optional. Comma-separated scopes that are REGISTERED in Kakao Developers.
# Examples:
#   KAKAO_SCOPES=profile_nickname
#   KAKAO_SCOPES=profile_nickname,profile_image
#   KAKAO_SCOPES=profile_nickname,profile_image,account_email  # email needs biz-app review
# If left blank, Kakao uses the required-consent items configured in the console.
KAKAO_SCOPES=

# JWT 서명 키 (세션 쿠키 서명) — `openssl rand -base64 48`. 32자 이상 필수.
# 바꾸면 기존 세션 전부 무효화(전원 재로그인). 여러 인스턴스는 같은 값 공유.
JWT_SECRET_KEY=replace-with-random-secret-32+chars
# Access 토큰(세션) 만료 — 분 단위. 기본 7일(10080).
JWT_ACCESS_EXPIRE_MINUTES=10080

# ── Super admin (워크스페이스 최상위 권한) — 이메일/비밀번호 로그인
#   비밀번호 해시 생성: 프로젝트 루트(이 .env 가 있는 폴더)에서 아래 명령 실행
#     npm run admin:hash
#   실행 위치: VS Code 통합 터미널 또는 Mac 터미널 (cd 후 실행)
#   → 비밀번호 입력(화면에 안 보임) → 출력된 SUPER_ADMIN_PASSWORD_HASH=... 줄을 아래에 붙여넣기
#   로그인: /ko/login → "관리자 로그인" (또는 /ko/login/admin)
#   슈퍼관리자로 들어간 뒤, 카카오 등 소셜 계정에 '사용자 관리'에서 admin 권한 부여
#   예)
#     SUPER_ADMIN_EMAIL=owner@codium-lab.com
#     SUPER_ADMIN_PASSWORD_HASH=scrypt:34782757aebc6e6f8882d20f2bb9479a:d91bac8799e900a361029bc52b1cc6a959779ac810db95dd95b309a5e336abbedd68013baeea1cd2ece5322e5af75555786c8faddbc603e3ef7416effa9d7713
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD_HASH=
# 표시 이름(선택, 기본값 "운영자"). 예) SUPER_ADMIN_NAME=데이먼
SUPER_ADMIN_NAME=

# ── 신규 문의 알림 메일 (Resend · 선택)
#   RESEND_API_KEY 가 없으면 메일 발송은 건너뛰고 문의는 DB 에만 저장됩니다.
#   1) https://resend.com 가입 → API Keys 에서 키 발급
#   2) INQUIRY_NOTIFY_TO 미설정 시 SUPER_ADMIN_EMAIL 로 발송
#   3) 도메인 인증 전에는 INQUIRY_NOTIFY_FROM 를 비워두면 onboarding@resend.dev 로 테스트 발송
#      (단, 이때 수신은 Resend 가입 이메일로만 가능). 도메인 인증 후 예) "코디움랩 <noreply@codium-lab.com>"
RESEND_API_KEY=
INQUIRY_NOTIFY_TO=
INQUIRY_NOTIFY_FROM=

# ── Future providers (placeholder)
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# META_CLIENT_ID=
# META_CLIENT_SECRET=
